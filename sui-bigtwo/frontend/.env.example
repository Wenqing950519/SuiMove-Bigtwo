# Sui Big Two V2 runtime environment

# Required. Use Neon Postgres or another production PostgreSQL database.
# Example:
# DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]/[DATABASE]?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bigtwo?schema=public"

# Required. Used to sign wallet-login session cookies.
# Generate a long random value before deploying.
AUTH_SECRET="change-me-to-a-long-random-production-secret"
